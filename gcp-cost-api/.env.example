# Copy to .env (or pass via --set-env-vars at deploy). No secrets belong here.
BQ_PROJECT=lucira-prod
# Fully-qualified DETAILED usage-cost export table (has resource.name):
BILLING_EXPORT_TABLE=lucira-prod.billing_export.gcp_billing_export_resource_v1_0123AB_45CDEF_6789GH
BILLING_CURRENCY=INR
TIMEZONE=Asia/Kolkata
WINDOW_DAYS=95
MONTHLY_BUDGET=180000
# JSON map of per-project monthly budgets (billing currency):
PROJECT_BUDGETS={"lucira-prod":105000,"lucira-analytics":42000,"lucira-staging":18000,"lucira-data-pipeline":15000}
LABEL_KEYS=env,team
