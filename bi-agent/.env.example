# Copy to .env for local runs (Cloud Run uses --set-env-vars / --set-secrets instead).
BI_CONFIG_DIR=config

# LLM (optional — absent = rule-based narrative). provider set in settings.yaml
LLM_API_KEY=

# WhatsApp Cloud API (optional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Email SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google auth: use Application Default Credentials (gcloud auth application-default login)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
