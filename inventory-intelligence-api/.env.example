# inventory-intelligence-api — environment
# Copy to .env for local dev (functions-framework reads real env vars, not .env,
# so `export`/`set` these before launch or use the deploy.sh --set-env-vars).

BQ_PROJECT=lucirajewelry-prod
REPORT_DATASET=lucirajewelry-prod.reporting

# Override individual tables only if you renamed them in the build SQL.
# FACT_TABLE=lucirajewelry-prod.reporting.inventory_intelligence_fact
# TRANSFERS_TABLE=lucirajewelry-prod.reporting.inventory_intelligence_transfers
# INSIGHTS_TABLE=lucirajewelry-prod.reporting.inventory_intelligence_insights
# META_TABLE=lucirajewelry-prod.reporting.inventory_intelligence_meta

CURRENCY=INR
TIMEZONE=Asia/Kolkata
ROW_CAP=12000

# Vertex AI (chat + narratives). The service account needs roles/aiplatform.user.
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
CHAT_MAX_GB=1
