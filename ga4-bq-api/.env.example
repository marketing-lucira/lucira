# ── ga4-bq-api configuration (copy to .env / set as Cloud Run env vars) ──
# No secrets belong in source or in git. Set GEMINI_API_KEY via Secret Manager.

GCP_PROJECT=lucirajewelry-prod
GA4_DASHBOARD_DATASET=ga4_dashboard        # destination dataset built by sql/00_setup.sql
GA4_CURRENCY=INR
WINDOW_DAYS=90                             # default trailing window for /data
MAX_DAYS=400
TOP_LIMIT=30                              # rows per breakdown table

# CORS: lock this to your Pages origin in production, e.g.
# https://marketing-lucira.github.io
CORS_ORIGIN=*

# /refresh + /report shared-secret (optional; Cloud Run IAM/OIDC is the primary guard).
# Leave empty to rely solely on Cloud Run authenticated invocations.
REFRESH_TOKEN=

# Gemini (AI insights / daily report / chat). Leave empty to run WITHOUT generative
# AI — the dashboard then uses its built-in local rule-based assistant.
GEMINI_API_KEY=
GA4_GEMINI_MODEL=gemini-2.0-flash
