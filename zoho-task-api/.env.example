# ============================================================
# Environment Variables — Zoho Task API
# Copy this file to .env and fill in actual values
# NEVER commit .env to Git!
# ============================================================

# ---- Zoho CRM OAuth Credentials ----
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here

# ---- Cloud SQL (PostgreSQL) Connection ----
DB_HOST=your_cloud_sql_public_ip_or_socket
DB_NAME=zoho_crm
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# ---- (Optional) For Cloud SQL Proxy / Unix socket ----
# DB_HOST=/cloudsql/project-id:region:instance-name
