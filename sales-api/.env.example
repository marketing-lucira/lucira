# sales-api — environment variables (copy to your deploy command / .env)
# ----------------------------------------------------------------------
BQ_PROJECT=lucirajewelry-prod
SALES_TABLE=lucirajewelry-prod.ornaverse_erp_administration.Sales_overview_table
TIMEZONE=Asia/Kolkata          # IST day boundary for date bucketing
CURRENCY=INR
WINDOW_DAYS=400                # order-line detail window pumped to the dashboard
MAX_WINDOW_DAYS=1200          # hard cap on ?days= request
DETAIL_ROW_CAP=120000         # safety cap on order-line rows returned in one call
