# ── Inventory Strategy API · environment ───────────────────────────────
# Copy to .env for local runs (functions-framework loads real env, not this file;
# use `set -a; source .env; set +a` or export manually). Cloud Run gets these via
# --set-env-vars in deploy.sh.

BQ_PROJECT=lucirajewelry-prod
INVENTORY_TABLE=lucirajewelry-prod.ds_imputed_reporting.Live_inventory
SALES_TABLE=lucirajewelry-prod.ornaverse_erp_administration.Sales_overview_table
GA4_DATASET=lucirajewelry-prod.analytics_478308692

TIMEZONE=Asia/Kolkata
CURRENCY=INR

# Dropped from the entire dashboard (comma-separated). Silver metal + all coins removed → jewelry only.
EXCLUDE_METALS=Silver
EXCLUDE_TYPES=Silver Coin,Gold Coin

# Velocity & reorder tuning (days)
VELOCITY_DAYS=90        # sales window used to compute run-rate
LEAD_TIME_DAYS=21       # supplier/production lead time for refill
SAFETY_DAYS=14          # safety-stock buffer on top of lead time
GEO_DAYS=30             # GA4 window for city/region demand

# Days-of-cover status thresholds
CRITICAL_COVER=14       # < this many days of cover  → CRITICAL
LOW_COVER=30            # < this  → LOW
OVERSTOCK_COVER=270     # > this  → OVERSTOCK
DEAD_DAYS=180           # no sale in window AND aged beyond this → DEAD stock

# Vertex AI (chat + AI strategy). Location is where the model runs, independent
# of the Cloud Run region. us-central1 has the widest Gemini availability.
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
CHAT_MAX_GB=2           # max BigQuery data a chat-generated query may bill
