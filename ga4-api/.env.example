# Copy to .env (or pass via --set-env-vars at deploy). No secrets belong here.
# Numeric GA4 property id (GA4 Admin → Property Settings → PROPERTY ID).
# This is NOT the "G-XXXXXXX" measurement id.
GA4_PROPERTY_ID=345678901
GA4_CURRENCY=INR
WINDOW_DAYS=90
# Rows returned for top-N reports (pages / sources / events):
TOP_LIMIT=30
# Optional metric-name overrides (leave unset — the function auto-detects).
# GA4 renamed "conversions" → "keyEvents" in 2024; auto-probe handles both.
# GA4_CONVERSION_METRIC=keyEvents
# GA4_REVENUE_METRIC=totalRevenue
